# Variables de entorno para el backend ADCP
# Copiar este archivo a .env y completar con sus valores

# Clave de API para el proveedor LLM (OpenAI por defecto)
OPENAI_API_KEY=your_openai_api_key_here

# Modelo LLM a usar (por defecto gpt-4o-mini para bajo costo)
OPENAI_MODEL_NAME=gpt-4o-mini

# Puerto del servidor (opcional, por defecto 8000)
# PORT=8000
